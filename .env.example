# =============================================================================
# Python Starter Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# Application
ENV=development
DEBUG=true
APP_NAME=python-starter
APP_VERSION=0.1.0

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
POSTGRES_DB=appdb
POSTGRES_URL=postgresql+asyncpg://dev:dev@localhost:5432/appdb

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Experiment Tracking
WANDB_PROJECT=python-starter
WANDB_API_KEY=
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=default

# Training
CUDA_VISIBLE_DEVICES=0
DEFAULT_DEVICE=auto

# Security (for production)
SECRET_KEY=change-me-in-production-at-least-32-characters-long
